// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  READONLY
}

enum CustomerStatus {
  NEW
  ACTIVE
  WAITING
  PROBLEM
  BLOCKED
  OLD
}

enum CustomerSource {
  FACEBOOK
  WHATSAPP
  REFERRAL
  WEBSITE
  TIKTOK
  OTHER
}

enum ProductCategory {
  CHATBOT
  DESIGN
  VIDEO
  AUDIO
  PRODUCTIVITY
  CODING
  OTHER
}

enum AccountType {
  INDIVIDUAL
  SHARED
  LICENSE_KEY
  INVITATION
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
  PENDING_SETUP
}

enum PaymentStatus {
  PAID
  PARTIALLY_PAID
  UNPAID
  REFUNDED
}

enum PaymentMethod {
  VODAFONE_CASH
  INSTAPAY
  BANK_TRANSFER
  CASH
  PAYPAL
  OTHER
}

// ==================== MODELS ====================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedCustomers Customer[]     @relation("AssignedEmployee")
  createdCustomers  Customer[]     @relation("CreatedByUser")
  subscriptions     Subscription[]
  payments          Payment[]
  notes             Note[]
  assignedTasks     Task[]         @relation("AssignedTasksTo")
  createdTasks      Task[]         @relation("CreatedTasksBy")
  activityLogs      ActivityLog[]

  @@index([role])
  @@index([isActive])
}

model Customer {
  id           String         @id @default(cuid())
  name         String
  phone        String?
  whatsapp     String?
  email        String?
  company      String?
  address      String?
  source       CustomerSource @default(OTHER)
  status       CustomerStatus @default(NEW)
  internalNote String?
  tags         String[]       @default([])
  assignedToId String?
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignedTo    User?          @relation("AssignedEmployee", fields: [assignedToId], references: [id])
  createdBy     User?          @relation("CreatedByUser", fields: [createdById], references: [id])
  subscriptions Subscription[]
  payments      Payment[]
  notes         Note[]
  tasks         Task[]

  @@index([assignedToId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model Product {
  id           String          @id @default(cuid())
  name         String
  provider     String
  category     ProductCategory @default(OTHER)
  planName     String
  durationDays Int
  sellingPrice Decimal         @db.Decimal(12, 2)
  costPrice    Decimal         @db.Decimal(12, 2)
  description  String?
  isActive     Boolean         @default(true)
  accountType  AccountType     @default(INDIVIDUAL)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
  @@index([category])
  @@index([provider])
}

model Subscription {
  id                     String             @id @default(cuid())
  customerId             String
  productId              String
  employeeId             String?
  startDate              DateTime
  endDate                DateTime
  renewalReminderDate    DateTime?
  salePrice              Decimal            @db.Decimal(12, 2)
  costPrice              Decimal            @db.Decimal(12, 2)
  paymentStatus          PaymentStatus      @default(UNPAID)
  status                 SubscriptionStatus @default(ACTIVE)
  paymentMethod          PaymentMethod      @default(CASH)
  notes                  String?
  encryptedLoginEmail    String?
  encryptedLoginPassword String?
  encryptedLicenseKey    String?
  encryptedAccessLink    String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
  employee  User?     @relation(fields: [employeeId], references: [id])
  payments  Payment[]
  notes_rel Note[]
  tasks     Task[]

  @@index([customerId])
  @@index([productId])
  @@index([employeeId])
  @@index([status])
  @@index([paymentStatus])
  @@index([endDate])
}

model Payment {
  id              String        @id @default(cuid())
  customerId      String
  subscriptionId  String?
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @default(CASH)
  paymentDate     DateTime      @default(now())
  referenceNumber String?
  status          PaymentStatus @default(PAID)
  notes           String?
  recordedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  recordedBy   User?         @relation(fields: [recordedById], references: [id])

  @@index([customerId])
  @@index([subscriptionId])
  @@index([paymentDate])
}

model Note {
  id             String    @id @default(cuid())
  content        String
  customerId     String?
  subscriptionId String?
  authorId       String?
  createdAt      DateTime  @default(now())

  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  author       User?         @relation(fields: [authorId], references: [id])

  @@index([customerId])
  @@index([subscriptionId])
  @@index([createdAt])
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime?
  isDone         Boolean   @default(false)
  customerId     String?
  subscriptionId String?
  assignedToId   String?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer     Customer?     @relation(fields: [customerId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  assignedTo   User?         @relation("AssignedTasksTo", fields: [assignedToId], references: [id])
  createdBy    User?         @relation("CreatedTasksBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([assignedToId])
  @@index([isDone])
  @@index([dueDate])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  details    String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model Settings {
  id                  String   @id @default(cuid())
  companyName         String   @default("Active Ai")
  logoPath            String   @default("/logo.png")
  currency            String   @default("EGP")
  reminderDays        Int      @default(7)
  whatsappTemplate    String   @default("أهلاً يا {customerName} 👋\n\nاشتراك {productName} الخاص بحضرتك هينتهي يوم {endDate}.\n\nتحب نجددلك الاشتراك؟ 🔄")
  rolePermissions     String   @default("{}")
  updatedAt           DateTime @updatedAt
}
